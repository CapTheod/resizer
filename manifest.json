{
  "manifest_version": 3,
  "name": "gemini resizer",
  "version": "0.0",
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/u/1/app/*"],
      "css": ["gemini.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.perplexity.ai/search*"],
      "css": ["perplexity.css"],
      "run_at": "document_start"
    }
  ]
}
